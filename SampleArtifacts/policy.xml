<policies>
	<inbound>
		<set-variable name="environmentName" value="{{environment-name}}" />
		<ip-filter action="allow">
			<address>10.0.0.1</address>
		</ip-filter>
		<set-header name="X-Sample-Environment" exists-action="override">
			<value>{{environment-name}}</value>
		</set-header>
		<include-fragment fragment-id="policyFragment1" />
	</inbound>
	<backend>
		<forward-request />
	</backend>
	<outbound>
		<set-header name="X-Response-Source" exists-action="append">
			<value>{{environment-name}}</value>
		</set-header>
	</outbound>
	<on-error />
</policies>
