<policies>
	<inbound>
		<set-backend-service base-url="{{intranet-proxy-url}}" />
		<set-header name="X-Api" exists-action="override">
			<value>basic-api</value>
		</set-header>
		<set-header name="X-Scenario-Environment" exists-action="append">
			<value>{{environment-name}}</value>
		</set-header>
	</inbound>
	<backend>
		<forward-request />
	</backend>
	<outbound />
	<on-error />
</policies>
